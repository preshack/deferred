# Deferred API — Environment Configuration
# Copy to .env and fill in values

# === Database ===
DATABASE_URL=postgresql+asyncpg://deferred:deferred_secret@localhost:5432/deferred_db
DATABASE_URL_SYNC=postgresql://deferred:deferred_secret@localhost:5432/deferred_db

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === RabbitMQ ===
RABBITMQ_URL=amqp://deferred:deferred_secret@localhost:5672/

# === JWT / Auth ===
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === Crypto ===
MASTER_ISSUER_SEED=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
ARGON2_MEMORY_KB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
API_TITLE=Deferred API
API_VERSION=1.0.0
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# === Observability ===
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=deferred-api
PROMETHEUS_ENABLED=true
